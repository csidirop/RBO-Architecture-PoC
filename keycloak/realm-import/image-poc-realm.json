{
  "realm": "image-poc",
  "enabled": true,
  "displayName": "Image Access PoC",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "image-reader",
        "description": "Can request protected files"
      }
    ]
  },
  "clients": [
    {
      "clientId": "middle-poc",
      "name": "Middle Service PoC",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/callback",
        "http://localhost:8080/oidc/callback"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "protocolMappers": [
        {
          "name": "realm roles for middle service",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "eduPersonEntitlement",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "eduPersonEntitlement",
            "id.token.claim": "true",
            "introspection.token.claim": "true",
            "jsonType.label": "String",
            "lightweight.claim": "false",
            "multivalued": "true",
            "user.attribute": "eduPersonEntitlement",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "eduPersonScopedAffiliation",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "eduPersonScopedAffiliation",
            "id.token.claim": "true",
            "introspection.token.claim": "true",
            "jsonType.label": "String",
            "lightweight.claim": "false",
            "multivalued": "true",
            "user.attribute": "eduPersonScopedAffiliation",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*"
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "ubma-dev",
      "displayName": "ubma-dev",
      "providerId": "oidc",
      "enabled": true,
      "config": {
        "authorizationUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/protocol/openid-connect/auth",
        "clientAuthMethod": "client_secret_post",
        "clientId": "rbo",
        "clientSecret": "${UBMA_IDP_CLIENT_SECRET}",
        "issuer": "https://auth.bib.uni-mannheim.de/realms/ubma-dev",
        "jwksUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/protocol/openid-connect/certs",
        "logoutUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/protocol/openid-connect/logout",
        "metadataDescriptorUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/.well-known/openid-configuration",
        "pkceEnabled": "false",
        "tokenIntrospectionUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/protocol/openid-connect/token/introspect",
        "tokenUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/protocol/openid-connect/token",
        "useJwksUrl": "true",
        "userInfoUrl": "https://auth.bib.uni-mannheim.de/realms/ubma-dev/protocol/openid-connect/userinfo",
        "validateSignature": "true"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "eduPersonScopedAffiliation",
      "identityProviderAlias": "ubma-dev",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "allow.nullable.property": "true",
        "claim": "eduPersonScopedAffiliation",
        "syncMode": "FORCE",
        "user.attribute": "eduPersonScopedAffiliation"
      }
    },
    {
      "name": "eduPersonEntitlement",
      "identityProviderAlias": "ubma-dev",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "allow.nullable.property": "true",
        "claim": "eduPersonEntitlement",
        "syncMode": "FORCE",
        "user.attribute": "eduPersonEntitlement"
      }
    }
  ],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"eduPersonEntitlement\",\"displayName\":\"\",\"validations\":{},\"annotations\":{},\"permissions\":{\"view\":[],\"edit\":[\"admin\"]},\"multivalued\":true},{\"name\":\"eduPersonScopedAffiliation\",\"displayName\":\"\",\"validations\":{},\"annotations\":{},\"permissions\":{\"view\":[],\"edit\":[\"admin\"]},\"multivalued\":true}],\"groups\":[{\"name\":\"user-metadata\",\"displayHeader\":\"User metadata\",\"displayDescription\":\"Attributes, which refer to user metadata\"}]}"
          ]
        }
      }
    ]
  },
  "users": [
    {
      "username": "reader",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Reader",
      "email": "reader@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "reader123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "image-reader"
      ]
    },
    {
      "username": "blocked",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Blocked",
      "email": "blocked@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "blocked123",
          "temporary": false
        }
      ]
    }
  ]
}
